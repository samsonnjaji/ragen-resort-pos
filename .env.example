# =============================================================================
# RAGEN RESORT POS — Environment variables
# Copy to .env for local dev, or set in Vercel → Project → Settings → Environment Variables
# =============================================================================

# Neon PostgreSQL connection string (pooled URL recommended for Vercel/serverless)
# Example: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Secure random secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Your deployment URL (no trailing slash)
# Production: https://your-app.vercel.app
# Local dev:  http://localhost:3000
NEXTAUTH_URL=

# Neon direct connection (non-pooled) — required for Prisma migrations on Neon
# Example: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# For local PostgreSQL, set DIRECT_URL to the same value as DATABASE_URL
DIRECT_URL=
