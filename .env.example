# Local development (SQLite — default, no PostgreSQL required)
DATABASE_URL="file:./dev.db"

# Production (PostgreSQL) — change prisma/schema.prisma provider to "postgresql"
# DATABASE_URL="postgresql://postgres:password@localhost:5432/ragen_resort?schema=public"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-secret-in-production"
