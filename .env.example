# =============================================================================
# RAGEN RESORT POS — Environment variables
# Copy to .env for local dev, or set in Vercel → Project → Settings → Environment Variables
# =============================================================================

# Neon PostgreSQL (pooled URL for app runtime)
DATABASE_URL=

# Neon direct URL (required for prisma migrate deploy)
DIRECT_URL=

# NextAuth
NEXTAUTH_SECRET=
# Production: https://ragen-resort-pos.vercel.app (no trailing slash)
NEXTAUTH_URL=

# Public production URL for email links (required on Vercel — do not use preview URLs)
# Production: https://ragen-resort-pos.vercel.app
APP_BASE_URL=

# Gmail / Google SMTP (use an App Password — not your normal Gmail password)
EMAIL_SERVER_HOST=smtp.gmail.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=
EMAIL_SERVER_PASSWORD=
EMAIL_FROM=
